	"type": "elgg-plugin",
	"description": "Autocomplete input",
	"homepage": "http://hypejunction.com",
	"keywords": [
		"elgg",
		"plugin",
		"autocomplete",
		"forms"
	],
	"license": "proprietary",
	"authors": [
		{
			"name": "Ismayil Khayredinov",
			"email": "info@hypejunction.com"
		}
	],
	"extra": {
		"installer-name": "hypeAutocomplete",
		"elgg-plugin": {
			"id": "hypeautocomplete"
		}
	},
	"require": {
		"php": ">=7.4",
		"composer/installers": "^2.0",
		"bower-asset/select2": "^4.0",
		"elgg/elgg": "^4.0"
	},
	"autoload": {
		"psr-0": {
			"": "classes/"
		}
	},
	"config": {
