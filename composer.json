{
    "name": "hypejunction/hypeautocomplete",
    "type": "elgg-plugin",
    "description": "Autocomplete input",
    "homepage": "https://github.com/hypeJunction/Elgg3-hypeAutocomplete",
    "keywords": [
        "elgg",
        "plugin",
        "autocomplete",
        "forms"
    ],
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Ismayil Khayredinov",
            "email": "ismayil.khayredinov@gmail.com"
        }
    ],
    "extra": {
        "installer-name": "hypeautocomplete",
        "elgg-plugin": {
            "id": "hypeautocomplete"
        }
    },
    "require": {
        "php": ">=8.3",
        "ext-intl": "*",
        "composer/installers": "^2.0",
        "bower-asset/select2": "^4.0",
        "elgg/elgg": "~7.0.0"
    },
    "autoload": {
        "psr-0": {
            "": "classes/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
